{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "chat.js", "use": "@vercel/node" },
    { "src": "search.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/chat", "dest": "/chat.js" },
    { "src": "/search", "dest": "/search.js" },
    { "src": "/", "dest": "/index.html" }
  ]
}
